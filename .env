PORT=8080
RELAY_TOKEN=change-this-to-a-long-random-secret

MQTT_URL=mqtt://broker.hivemq.com:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CMD_TOPIC=neckremote/demo1/cmd
